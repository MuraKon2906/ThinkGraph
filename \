def extract_title_and_abstract(docs) -> tuple[str, str]:
    """
    Extracts the paper title and abstract from loaded PDF pages.

    Title   = first non-empty line in the document.
    Abstract = text block that follows an "Abstract" header line, stopping
               at the first subsequent section marker (e.g. "1 Introduction",
               "Keywords", "I. INTRODUCTION", etc.).
               Falls back to the first 15 meaningful lines if no abstract marker
               is found (rare, but handles non-standard layouts).
    """

    # Flatten all pages into one line list
    full_text = "\n".join(page.page_content for page in docs)
    lines     = [l.strip() for l in full_text.splitlines()]
    non_empty = [l for l in lines if l]

    # Title: first non-empty line
    title = non_empty[0] if non_empty else "Academic Paper"

    # Matches a standalone "Abstract" header (the whole line is just that word)
    abstract_header = re.compile(r"^abstract[\s\.\-\u2014:]*$", re.IGNORECASE)

    # Matches inline abstract: "Abstract— We propose..." or "Abstract: ..."
    abstract_inline = re.compile(
        r"^abstract[\s\.\-\u2014:]+(.+)", re.IGNORECASE
    )

    # Marks the start of the next section — stops abstract collection
    next_section = re.compile(
        r"^(\d+[\.\s]+\w|[IVX]+[\.\s]+\w|keywords?[\s:\u2013\u2014]|"
        r"introduction|related work|conclusion|acknowledgements?)",
        re.IGNORECASE,
    )

    abstract_lines: list[str] = []
    in_abstract = False

    for line in lines:
        if not in_abstract:
            # Case 1: standalone "Abstract" header on its own line
            if abstract_header.match(line):
                in_abstract = True
                continue

            # Case 2: "Abstract— text starts here on same line"
            m = abstract_inline.match(line)
            if m:
                in_abstract = True
                abstract_lines.append(m.group(1).strip())
                continue
        else:
            # Stop as soon as a new section begins
            if line and next_section.match(line):
                break
            if line:
                abstract_lines.append(line)

    if abstract_lines:
        abstract_text = " ".join(abstract_lines)
        snippet = f"Title: {title}\n\nAbstract:\n{abstract_text}"
    else:
        # Fallback: title + next 15 meaningful lines
        snippet = "Title: {}\n\n{}".format(title, "\n".join(non_empty[1:16]))

    return title, snippet


def fetch_related_links(title: str) -> list[dict]:
    """Use Tavily to find links related to the paper title."""
    if not tavily_key:
        return []
    try:
        client  = TavilyClient(api_key=tavily_key)
        results = client.search(
            query=f'academic paper research "{title}"',
            search_depth="basic",
            max_results=5,
        )
        return [
            {
                "title":   r.get("title", ""),
                "url":     r.get("url", ""),
                "snippet": r.get("content", "")[:200],
            }
            for r in results.get("results", [])
        ]
    except Exception:
        return []


@api_view(["POST"])
def query_view(request):
    prompt   = request.data.get("prompt", "")
    material = request.FILES.get("material")

    if not prompt:
        return Response(
            {"error": "Prompt is required"},
            status=status.HTTP_400_BAD_REQUEST,
        )

    try:
        embeddings = GoogleGenerativeAIEmbeddings(
            model="models/gemini-embedding-2-preview",
            google_api_key=api_key,
        )
        llm = ChatGoogleGenerativeAI(
            model="gemini-2.5-flash",
            temperature=0.3,
            google_api_key=api_key,
        )

        related_links: list[dict] = []

        if material:
            # 1. Write upload to a temp file
            suffix = os.path.splitext(material.name)[-1]
            with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
                for chunk in material.chunks():
                    tmp.write(chunk)
                tmp.flush()
                tmp_path = tmp.name

            # 2. Load PDF
            loader = PyPDFLoader(tmp_path)
            docs   = loader.load()
            os.unlink(tmp_path)

            # 3. Extract title + abstract (the only context sent to RAG)
            title, snippet = extract_title_and_abstract(docs)

            # 4. Related links via Tavily (keyed on title)
            related_links = fetch_related_links(title)

            # 5. Single-document vector store — title + abstract only
            snippet_doc = Document(
                page_content=snippet,
                metadata={"source": material.name},
            )
            vectorstore = FAISS.from_documents([snippet_doc], embeddings)
            retriever   = vectorstore.as_retriever(search_kwargs={"k": 1})

            # 6. RAG chain
            rag_prompt = ChatPromptTemplate.from_template("""
You are an expert research analyst specialising in academic papers.
Answer the user's question using ONLY the context provided below,
which contains the paper's title and abstract.
Format your response in markdown. Use headers, bullet points, and
LaTeX math ($$...$$) where appropriate.
If the answer cannot be found in the context, say so clearly.

Context:
{context}

Question: {input}
""")
            chain  = create_retrieval_chain(
                retriever,
                create_stuff_documents_chain(llm, rag_prompt),
            )
            result = chain.invoke({"input": prompt})
            answer = result["answer"]

        else:
            result = llm.invoke(prompt)
            answer = result.content

        return Response({"answer": answer, "related_links": related_links})

    except Exception as e:
        import traceback
        traceback.print_exc()
        return Response(
            {"error": str(e)},
            status=status.HTTP_500_INTERNAL_SERVER_ERROR,
        )
